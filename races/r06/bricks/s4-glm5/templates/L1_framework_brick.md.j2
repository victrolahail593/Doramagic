{#
L1 框架级积木模板

Token 预算: 200-400 tokens
内容: WHY 哲学 + 心智模型

适用于:
- 框架设计哲学
- 核心心智模型
- 跨项目通用的理念层知识

使用方式:
    from jinja2 import Environment, FileSystemLoader
    env = Environment(loader=FileSystemLoader('templates'))
    template = env.get_template('L1_framework_brick.md.j2')
    output = template.render(**context)
#}
---
brick_id: {{ domain_id }}-{{ brick_name }}-L1
domain_id: {{ domain_id }}
layer: L1
knowledge_type: {{ knowledge_type | default('rationale') }}
confidence: {{ confidence | default('high') }}
signal: {{ signal | default('ALIGNED') }}
source_project_ids:
{% for project_id in source_project_ids %}
  - {{ project_id }}
{% endfor %}
support_count: {{ support_count | default(2) }}
tags:
{% for tag in tags %}
  - {{ tag }}
{% endfor %}
version: "{{ version | default('1.0.0') }}"
deprecated: false
---

# Design Philosophy

{{ design_philosophy }}

{% if mental_models %}
# Mental Models

{{ mental_models }}
{% endif %}

{% if implications %}
# Implications

{{ implications }}
{% endif %}

---
<!--
Token Estimate: ~{{ token_estimate | default(300) }} tokens
Last Updated: {{ last_updated | default('2026-03-20') }}
Review Status: {{ review_status | default('pending') }}
-->