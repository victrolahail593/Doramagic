{#
L2 模式级积木模板

Token 预算: 400-800 tokens
内容: UNSAID + 速查规则 + 反模式

适用于:
- 具体模式的隐含知识
- 常见陷阱和反模式
- 可执行的速查规则

使用方式:
    from jinja2 import Environment, FileSystemLoader
    env = Environment(loader=FileSystemLoader('templates'))
    template = env.get_template('L2_pattern_brick.md.j2')
    output = template.render(**context)
#}
---
brick_id: {{ domain_id }}-{{ brick_name }}-L2
domain_id: {{ domain_id }}
layer: L2
knowledge_type: {{ knowledge_type | default('assembly_pattern') }}
confidence: {{ confidence | default('medium') }}
signal: {{ signal | default('ALIGNED') }}
source_project_ids:
{% for project_id in source_project_ids %}
  - {{ project_id }}
{% endfor %}
support_count: {{ support_count | default(2) }}
tags:
{% for tag in tags %}
  - {{ tag }}
{% endfor %}
version: "{{ version | default('1.0.0') }}"
deprecated: false
---

{% if design_philosophy %}
# Design Philosophy

{{ design_philosophy }}

{% endif %}
{% if mental_models %}
# Mental Models

{{ mental_models }}

{% endif %}
# UNSAID Knowledge

{{ unsaid_knowledge }}

# Quick Rules

{% for rule in quick_rules %}
{{ loop.index }}. {{ rule }}
{% endfor %}

{% if implications %}
# Implications

{{ implications }}

{% endif %}
{% if anti_patterns %}
# Anti-Patterns

{{ anti_patterns }}

{% endif %}
---
<!--
Token Estimate: ~{{ token_estimate | default(600) }} tokens
Last Updated: {{ last_updated | default('2026-03-20') }}
Review Status: {{ review_status | default('pending') }}
Common Pitfalls Coverage: {{ pitfall_coverage | default('high') }}
-->